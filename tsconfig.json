{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "lib": ["ES2022", "DOM"],
    "types": ["node"],
    "strict": true,
    "noEmit": true,
    "allowJs": false,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "useDefineForClassFields": true
  },
  "include": [
    ".vitepress/**/*.ts",
    ".vitepress/**/*.d.ts"
  ],
  "exclude": [
    ".vitepress/dist",
    ".vitepress/cache",
    "node_modules"
  ]
}
